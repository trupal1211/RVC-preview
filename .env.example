# Contact API URL - points to Vercel serverless function
VITE_CONTACT_API_URL=/api/contact

# reCAPTCHA v3 site key
# Generate at: https://www.google.com/recaptcha/admin
# 1. Select "reCAPTCHA v3"
# 2. Add your domain (e.g. www.relationshipvista.com)
# 3. Copy the "Site Key" here
VITE_RECAPTCHA_SITE_KEY=your_recaptcha_site_key_here

# SMTP credentials (set in Vercel Environment Variables, NOT here)
# SMTP_USER=parambuddh26@gmail.com
# SMTP_PASS=your_gmail_app_password
